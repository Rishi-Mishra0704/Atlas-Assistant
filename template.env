QDRANT_URL=http://localhost:6333

# Application database URLs
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/postgres

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_INTENT_MODEL=qwen2.5:0.5b